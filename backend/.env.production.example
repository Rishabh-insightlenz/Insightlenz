# ── InsightLenz Backend — Production Environment Variables ──────────────────
# Copy these into your Render / Railway dashboard as environment variables.
# NEVER commit the real values to git.

APP_ENV=production
DEBUG=false
APP_SECRET_KEY=change-me-use-a-long-random-string

# Supabase PostgreSQL connection string
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# AI — Groq free tier
ACTIVE_AI_PROVIDER=groq
ACTIVE_AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_...

# Leave blank if not using
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
